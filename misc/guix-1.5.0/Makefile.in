	@$(MKDIR_P) nix/nix-daemon
	@: >>nix/nix-daemon/$(am__dirstamp)
nix/nix-daemon/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) nix/nix-daemon/$(DEPDIR)
	@: >>nix/nix-daemon/$(DEPDIR)/$(am__dirstamp)
nix/nix-daemon/guix_daemon-nix-daemon.$(OBJEXT):  \
