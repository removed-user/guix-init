@CAN_RUN_TESTS_TRUE@  tests/guix-archive.sh				\
@CAN_RUN_TESTS_TRUE@  tests/guix-authenticate.sh			\
@CAN_RUN_TESTS_TRUE@  tests/guix-environment.sh			\
@CAN_RUN_TESTS_TRUE@  tests/guix-environment-container.sh		\
@CAN_RUN_TESTS_TRUE@  tests/guix-refresh.sh				\
@CAN_RUN_TESTS_TRUE@  tests/guix-shell.sh				\
@CAN_RUN_TESTS_TRUE@  tests/guix-shell-export-manifest.sh		\
@CAN_RUN_TESTS_TRUE@  tests/guix-time-machine.sh			\
@CAN_RUN_TESTS_TRUE@  tests/guix-graph.sh				\
@CAN_RUN_TESTS_TRUE@  tests/guix-describe.sh			\
@CAN_RUN_TESTS_TRUE@  tests/guix-repl.sh     			\
@CAN_RUN_TESTS_TRUE@  tests/guix-lint.sh

@CAN_RUN_TESTS_TRUE@AM_TESTS_ENVIRONMENT =  \
@CAN_RUN_TESTS_TRUE@	abs_top_srcdir="$(abs_top_srcdir)" \
@CAN_RUN_TESTS_TRUE@	GUILE_AUTO_COMPILE=0 $(am__append_22)
@CAN_RUN_TESTS_TRUE@SCM_LOG_DRIVER = \
@CAN_RUN_TESTS_TRUE@  $(top_builddir)/test-env --quiet-stderr	\
@CAN_RUN_TESTS_TRUE@  $(GUILE) --no-auto-compile -e main		\
@CAN_RUN_TESTS_TRUE@      $(top_srcdir)/build-aux/test-driver.scm

@CAN_RUN_TESTS_TRUE@AM_SCM_LOG_DRIVER_FLAGS = --brief=yes
@CAN_RUN_TESTS_TRUE@SH_LOG_COMPILER = $(top_builddir)/test-env $(SHELL)
@CAN_RUN_TESTS_TRUE@AM_SH_LOG_FLAGS = -x -e

# Public keys used to sign substitutes.
dist_pkgdata_DATA = \
  etc/substitutes/berlin.guix.gnu.org.pub	\
  etc/substitutes/ci.guix.gnu.org.pub		\
  etc/substitutes/ci.guix.info.pub		\
  etc/substitutes/bordeaux.guix.gnu.org.pub


# Bash completion file.
dist_bashcompletion_DATA = etc/completion/bash/guix	\
  etc/completion/bash/guix-daemon


# Zsh completion file.
dist_zshcompletion_DATA = etc/completion/zsh/_guix

# Fish completion file.
dist_fishcompletion_DATA = etc/completion/fish/guix.fish

# SELinux policy
nodist_selinux_policy_DATA = etc/guix-daemon.cil

# AppArmor profiles.
dist_apparmor_profile_DATA = \
  etc/apparmor.d/guix		\
  etc/apparmor.d/guix-daemon

nodist_apparmor_profile_tunables_DATA = \
  etc/apparmor.d/tunables/guix

CLEANFILES = $(bin_SCRIPTS) $(GOBJECTS) $(SCM_TESTS:tests/%.scm=%.log) \
	$(am__append_19)

# Split compilation in several steps, each of which building a subset of
# $(MODULES).  The main goal is to reduce peak memory consumption, as reported
# in <https://issues.guix.gnu.org/48963>.  Each 'eval' call below creates a
# 'make-*-go' phony target that builds the corresponding subset.
first_fifth := \
  gnu/packages/a% gnu/packages/b% gnu/packages/c%

second_fifth := \
  gnu/packages/d% gnu/packages/e% gnu/packages/f%

third_fifth := \
  gnu/packages/g%  gnu/packages/h% gnu/packages/i%

fourth_fifth := \
  gnu/packages/j% gnu/packages/k% gnu/packages/l% gnu/packages/m% 	\
  gnu/packages/n% gnu/packages/o%

MODULES_CORE := guix.scm $(filter-out guix/scripts/%,$(filter guix/%,$(MODULES)))
MODULES_PACKAGES1 := $(filter $(first_fifth),$(MODULES))
MODULES_PACKAGES2 := $(filter $(second_fifth),$(MODULES))
MODULES_PACKAGES3 := $(filter $(third_fifth),$(MODULES))
MODULES_PACKAGES4 := $(filter $(fourth_fifth),$(MODULES))
MODULES_PACKAGES5 := $(filter-out $(first_fifth) $(second_fifth)	\
			$(third_fifth) $(fourth_fifth),			\
			$(filter gnu/packages/%,$(MODULES)))

MODULES_PACKAGES := $(MODULES_PACKAGES1) $(MODULES_PACKAGES2)		\
			$(MODULES_PACKAGES3) $(MODULES_PACKAGES4)	\
			$(MODULES_PACKAGES5)

MODULES_SYSTEM := gnu.scm $(filter-out gnu/packages/%,$(filter gnu/%,$(MODULES)))
MODULES_CLI := $(filter guix/scripts/%,$(MODULES))
MODULES_PO := guix/build/po.scm
SUFFIXES = .go

# Make sure source files are installed first, so that the mtime of
# installed compiled files is greater than that of installed source
# files.  See
# <http://lists.gnu.org/archive/html/guile-devel/2010-07/msg00125.html>
# for details.
guix_install_go_files = install-nobase_nodist_guileobjectDATA
SUBDIRS = po/guix po/packages

# Bundle this file so that makeinfo finds it in out-of-source-tree builds.
BUILT_SOURCES = $(OS_CONFIG_EXAMPLES_TEXI) $(TRANSLATED_INFO) \
	$(am__append_18) $(top_srcdir)/.version $(am__append_24)

# If adding a language, update the following variables, and info_TEXINFOS.
MANUAL_LANGUAGES = de es fr it pt_BR ru zh_CN
COOKBOOK_LANGUAGES = de es fr it ko pt_BR ru sk sv ta zh_CN

# Arg1: A list of languages codes.
# Arg2: The file name stem.
lang_to_texinfo = $(foreach lang,$(1),doc/$(2).$(lang).texi)

# Automake does not understand GNU Make non-standard extensions,
# unfortunately, so we cannot use the above patsubst-based function here.
info_TEXINFOS = doc/guix.texi			\
  doc/guix.de.texi				\
  doc/guix.es.texi				\
  doc/guix.fr.texi				\
  doc/guix.it.texi				\
  doc/guix.pt_BR.texi				\
  doc/guix.ru.texi				\
  doc/guix.zh_CN.texi				\
  doc/guix-cookbook.texi			\
  doc/guix-cookbook.de.texi			\
  doc/guix-cookbook.es.texi			\
  doc/guix-cookbook.fr.texi			\
  doc/guix-cookbook.it.texi			\
  doc/guix-cookbook.ko.texi			\
  doc/guix-cookbook.pt_BR.texi			\
  doc/guix-cookbook.ru.texi			\
  doc/guix-cookbook.sk.texi			\
  doc/guix-cookbook.sv.texi			\
  doc/guix-cookbook.ta.texi			\
  doc/guix-cookbook.zh_CN.texi

doc_guix_TEXINFOS = \
  $(OS_CONFIG_EXAMPLES_TEXI) \
  doc/contributing.texi \
  doc/fdl-1.3.texi

DOT_FILES = \
  doc/images/bootstrap-graph.dot		\
  doc/images/bootstrap-packages.dot		\
  doc/images/coreutils-graph.dot		\
  doc/images/coreutils-bag-graph.dot		\
  doc/images/gcc-core-mesboot0-graph.dot	\
  doc/images/service-graph.dot			\
  doc/images/shepherd-graph.dot

DOT_VECTOR_GRAPHICS = \
  $(DOT_FILES:%.dot=%.eps)			\
  $(DOT_FILES:%.dot=%.pdf)

OS_CONFIG_EXAMPLES_TEXI = \
  doc/os-config-bare-bones.texi			\
  doc/os-config-desktop.texi			\
  doc/os-config-lightweight-desktop.texi	\
  doc/he-config-bare-bones.scm

TRANSLATED_INFO = \
  $(call lang_to_texinfo,$(MANUAL_LANGUAGES),guix)		\
  $(call lang_to_texinfo,$(MANUAL_LANGUAGES),contributing)	\
  $(call lang_to_texinfo,$(COOKBOOK_LANGUAGES),guix-cookbook)

MAINTAINERCLEANFILES = $(OS_CONFIG_EXAMPLES_TEXI) $(TRANSLATED_INFO)

# If /dev/null is used for this POT file path, a warning will be issued
# because the path extension is not 'pot'.
dummy_pot = $(shell mktemp --suffix=.pot)
infoimagedir = $(infodir)/images
dist_infoimage_DATA = \
  $(DOT_FILES:%.dot=%.png)			\
  doc/images/coreutils-size-map.png		\
  doc/images/installer-network.png		\
  doc/images/installer-partitions.png		\
  doc/images/installer-resume.png


# Ask for warnings about cross-referenced manuals that are not listed in
# htmlxref.cnf.
AM_MAKEINFOHTMLFLAGS = --set-customization-variable CHECK_HTMLXREF=true

# Try hard to obtain an image size and aspect that's reasonable for inclusion
# in an Info or PDF document.
DOT_OPTIONS = \
  -Gratio=.9 -Gnodesep=.005 -Granksep=.00005	\
  -Nfontsize=9 -Nheight=.1 -Nwidth=.1


# The man pages are generated using GNU Help2man.  In makefiles rules they
# depend not on the binary, but on the source files.  This usage allows a
# manual page to be generated by the maintainer and included in the
# distribution without requiring the end-user to have 'help2man' installed.
# They are built in $(srcdir) like info manuals.
sub_commands_mans = $(srcdir)/doc/guix-archive.1 \
	$(srcdir)/doc/guix-build.1 $(srcdir)/doc/guix-challenge.1 \
	$(srcdir)/doc/guix-container.1 $(srcdir)/doc/guix-deploy.1 \
	$(srcdir)/doc/guix-describe.1 $(srcdir)/doc/guix-download.1 \
	$(srcdir)/doc/guix-edit.1 $(srcdir)/doc/guix-environment.1 \
	$(srcdir)/doc/guix-gc.1 $(srcdir)/doc/guix-git.1 \
	$(srcdir)/doc/guix-graph.1 $(srcdir)/doc/guix-hash.1 \
	$(srcdir)/doc/guix-home.1 $(srcdir)/doc/guix-import.1 \
	$(srcdir)/doc/guix-lint.1 $(srcdir)/doc/guix-offload.1 \
	$(srcdir)/doc/guix-pack.1 $(srcdir)/doc/guix-package.1 \
	$(srcdir)/doc/guix-processes.1 $(srcdir)/doc/guix-publish.1 \
	$(srcdir)/doc/guix-pull.1 $(srcdir)/doc/guix-refresh.1 \
	$(srcdir)/doc/guix-repl.1 $(srcdir)/doc/guix-shell.1 \
	$(srcdir)/doc/guix-size.1 $(srcdir)/doc/guix-style.1 \
	$(srcdir)/doc/guix-system.1 $(srcdir)/doc/guix-time-machine.1 \
	$(srcdir)/doc/guix-weather.1 $(am__append_16)

# Assume that cross-compiled commands cannot be executed.
@CROSS_COMPILING_FALSE@dist_man1_MANS = $(srcdir)/doc/guix.1 \
@CROSS_COMPILING_FALSE@	$(sub_commands_mans) $(am__append_17)
gen_man = \
  LANGUAGE= $(top_builddir)/pre-inst-env $(HELP2MAN)	\
  $(HELP2MANFLAGS)

HELP2MANFLAGS = --source=GNU --info-page=$(PACKAGE_TARNAME)
# help2man reproducibility
SOURCE_DATE_EPOCH = $(shell git show HEAD --format=%ct --no-patch 2>/dev/null || echo 1)

# Reproducible tarball
DIST_CONFIGURE_FLAGS = \
  --localstatedir=/var				\
  --sysconfdir=/etc

@BUILD_DAEMON_TRUE@noinst_LIBRARIES = libutil.a libstore.a

# Use '-std=c++20' for 'std::shared_ptr', 'auto', lambdas, and more.
@BUILD_DAEMON_TRUE@AM_CXXFLAGS = -Wall -std=c++20
@BUILD_DAEMON_TRUE@libutil_a_SOURCES = \
@BUILD_DAEMON_TRUE@  nix/libutil/archive.cc			\
@BUILD_DAEMON_TRUE@  nix/libutil/affinity.cc			\
@BUILD_DAEMON_TRUE@  nix/libutil/serialise.cc			\
@BUILD_DAEMON_TRUE@  nix/libutil/util.cc				\
@BUILD_DAEMON_TRUE@  nix/libutil/hash.cc				\
@BUILD_DAEMON_TRUE@  nix/libutil/spawn.cc				\
@BUILD_DAEMON_TRUE@  nix/libutil/seccomp.cc

@BUILD_DAEMON_TRUE@libutil_headers = \
@BUILD_DAEMON_TRUE@  nix/libutil/affinity.hh			\
@BUILD_DAEMON_TRUE@  nix/libutil/hash.hh				\
@BUILD_DAEMON_TRUE@  nix/libutil/serialise.hh			\
@BUILD_DAEMON_TRUE@  nix/libutil/util.hh				\
@BUILD_DAEMON_TRUE@  nix/libutil/archive.hh			\
@BUILD_DAEMON_TRUE@  nix/libutil/types.hh				\
@BUILD_DAEMON_TRUE@  nix/libutil/spawn.hh				\
@BUILD_DAEMON_TRUE@  nix/libutil/seccomp.hh

@BUILD_DAEMON_TRUE@libutil_a_CPPFLAGS = \
@BUILD_DAEMON_TRUE@  -I$(top_builddir)/nix				\
@BUILD_DAEMON_TRUE@  -I$(top_srcdir)/nix/libutil			\
@BUILD_DAEMON_TRUE@  $(LIBGCRYPT_CPPFLAGS)

@BUILD_DAEMON_TRUE@libstore_a_SOURCES = \
@BUILD_DAEMON_TRUE@  nix/libstore/gc.cc				\
@BUILD_DAEMON_TRUE@  nix/libstore/globals.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/misc.cc				\
@BUILD_DAEMON_TRUE@  nix/libstore/references.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/store-api.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/optimise-store.cc		\
@BUILD_DAEMON_TRUE@  nix/libstore/local-store.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/build.cc				\
@BUILD_DAEMON_TRUE@  nix/libstore/pathlocks.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/derivations.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/builtins.cc			\
@BUILD_DAEMON_TRUE@  nix/libstore/sqlite.cc

@BUILD_DAEMON_TRUE@libstore_headers = \
@BUILD_DAEMON_TRUE@  nix/libstore/references.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/pathlocks.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/globals.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/worker-protocol.hh		\
@BUILD_DAEMON_TRUE@  nix/libstore/derivations.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/misc.hh				\
@BUILD_DAEMON_TRUE@  nix/libstore/local-store.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/sqlite.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/builtins.hh			\
@BUILD_DAEMON_TRUE@  nix/libstore/store-api.hh

@BUILD_DAEMON_TRUE@libstore_a_CPPFLAGS = \
@BUILD_DAEMON_TRUE@  $(libutil_a_CPPFLAGS)				\
@BUILD_DAEMON_TRUE@  -I$(top_srcdir)/nix/libstore			\
@BUILD_DAEMON_TRUE@  -I$(top_builddir)/nix/libstore		\
@BUILD_DAEMON_TRUE@  -DNIX_STORE_DIR=\"$(storedir)\"		\
@BUILD_DAEMON_TRUE@  -DNIX_STATE_DIR=\"$(localstatedir)/guix\"	\
@BUILD_DAEMON_TRUE@  -DNIX_LOG_DIR=\"$(localstatedir)/log/guix\"	\
@BUILD_DAEMON_TRUE@  -DGUIX_CONFIGURATION_DIRECTORY=\"$(sysconfdir)/guix\"		\
@BUILD_DAEMON_TRUE@  -DNIX_BIN_DIR=\"$(bindir)\"			\
@BUILD_DAEMON_TRUE@  -DDEFAULT_CHROOT_DIRS="\"\""

@BUILD_DAEMON_TRUE@libstore_a_CXXFLAGS = $(AM_CXXFLAGS)		\
@BUILD_DAEMON_TRUE@  $(SQLITE3_CFLAGS)

@BUILD_DAEMON_TRUE@guix_daemon_SOURCES = \
@BUILD_DAEMON_TRUE@  nix/nix-daemon/nix-daemon.cc			\
@BUILD_DAEMON_TRUE@  nix/nix-daemon/guix-daemon.cc

@BUILD_DAEMON_TRUE@guix_daemon_CPPFLAGS = \
@BUILD_DAEMON_TRUE@  -DLOCALEDIR=\"$(localedir)\"			\
@BUILD_DAEMON_TRUE@  $(libutil_a_CPPFLAGS)				\
@BUILD_DAEMON_TRUE@  -I$(top_srcdir)/nix/libstore

@BUILD_DAEMON_TRUE@guix_daemon_LDFLAGS = \
@BUILD_DAEMON_TRUE@  $(LIBGCRYPT_LDFLAGS)

@BUILD_DAEMON_TRUE@guix_daemon_LDADD = libstore.a libutil.a -lz \
@BUILD_DAEMON_TRUE@	$(SQLITE3_LIBS) $(LIBGCRYPT_LIBS) \
@BUILD_DAEMON_TRUE@	$(am__append_20)
@BUILD_DAEMON_TRUE@guix_daemon_headers = \
@BUILD_DAEMON_TRUE@  nix/nix-daemon/nix-daemon.hh

@BUILD_DAEMON_TRUE@noinst_HEADERS = \
@BUILD_DAEMON_TRUE@  $(libutil_headers) $(libstore_headers)	\
@BUILD_DAEMON_TRUE@  $(guix_daemon_headers)


# The '.service' and other files for systemd.
@BUILD_DAEMON_TRUE@systemdservicedir = $(libdir)/systemd/system
@BUILD_DAEMON_TRUE@nodist_systemdservice_DATA = \
@BUILD_DAEMON_TRUE@  etc/gnu-store.mount				\
@BUILD_DAEMON_TRUE@  etc/guix-daemon.service			\
@BUILD_DAEMON_TRUE@  etc/guix-publish.service			\
@BUILD_DAEMON_TRUE@  etc/guix-gc.service				\
@BUILD_DAEMON_TRUE@  etc/guix-gc.timer


# The service script for sysvinit.
@BUILD_DAEMON_TRUE@sysvinitservicedir = $(sysconfdir)/init.d
@BUILD_DAEMON_TRUE@nodist_sysvinitservice_DATA = etc/init.d/guix-daemon

# The service script for openrc.
@BUILD_DAEMON_TRUE@openrcservicedir = $(sysconfdir)/openrc
@BUILD_DAEMON_TRUE@nodist_openrcservice_DATA = etc/openrc/guix-daemon

# The '.conf' jobs for Upstart.
@BUILD_DAEMON_TRUE@upstartjobdir = $(libdir)/upstart/system
@BUILD_DAEMON_TRUE@nodist_upstartjob_DATA = etc/guix-daemon.conf etc/guix-publish.conf
ACLOCAL_AMFLAGS = -I m4

# Pass an explicit '--localstatedir' so that configure does not error out if
# it finds an existing installation with a different localstatedir.  Inherit
# 'ac_cv_guix_test_root' so that "make check" in $(distdir) does not have to
# repopulate the whole store, and to make sure $(GUIX_TEST_ROOT) is short
# enough for shebangs.
AM_DISTCHECK_CONFIGURE_FLAGS = \
  --localstatedir="$$dc_install_base/var"	\
  --with-libgcrypt-prefix="$(LIBGCRYPT_PREFIX)"	\
  --with-libgcrypt-libdir="$(LIBGCRYPT_LIBDIR)"	\
  --enable-daemon				\
  ac_cv_guix_test_root="$(GUIX_TEST_ROOT)"

@in_git_p_TRUE@git_version = $(shell build-aux/git-version-gen .tarball-version)
releasedir = release-$(PACKAGE_VERSION)
PACKAGE_FULL_TARNAME = $(PACKAGE_TARNAME)-$(PACKAGE_VERSION)

# List of source tarballs produced.  This must be kept in sync with the
# 'dist-' options of 'AM_INIT_AUTOMAKE' in 'configure.ac'.
SOURCE_TARBALLS = \
  $(foreach ext,tar.gz,$(PACKAGE_FULL_TARNAME).$(ext))


# Guix binary tarballs.
BINARY_TARBALLS = \
  $(foreach system,$(SUPPORTED_SYSTEMS),guix-binary.$(system).tar.xz)


# Prefix of the Guix installation image file name.
GUIX_SYSTEM_IMAGE_BASE = guix-system-install-$(PACKAGE_VERSION)

# Prefix of the Guix VM image file name.
GUIX_SYSTEM_VM_IMAGE_BASE = guix-system-vm-image-$(PACKAGE_VERSION)

# Return the sequence of '-s' flags for the given systems.
system_flags = $(foreach system,$(1),-s $(system))
COMMIT_MSG_MAGIC = VGhpcyBpcyB0aGUgY29tbWl0LW1zZyBob29rIG9mIEd1aXg=

# The etc/git/ config files are not distributed and have no use when building
# from a tarball.  Do not add dependencies on these to *_DATA when building
# from a tarball, as that breaks the build.
@in_git_p_TRUE@nodist_noinst_DATA = \
@in_git_p_TRUE@  .git/hooks/pre-push				\
@in_git_p_TRUE@  .git/hooks/post-merge				\
@in_git_p_TRUE@  .git/config					\
@in_git_p_TRUE@  .git/hooks/commit-msg


# Downloading up-to-date PO files.
WEBLATE_REPO = https://codeberg.org/guix/translations
AM_V_DL = $(AM_V_DL_$(V))
AM_V_DL_ = $(AM_V_DL_$(AM_DEFAULT_VERBOSITY))
AM_V_DL_0 = @echo "  DL      " $@;
AM_V_DOT = $(AM_V_DOT_$(V))
AM_V_DOT_ = $(AM_V_DOT_$(AM_DEFAULT_VERBOSITY))
AM_V_DOT_0 = @echo "  DOT     " $@;
AM_V_HELP2MAN = $(AM_V_HELP2MAN_$(V))
AM_V_HELP2MAN_ = $(AM_V_HELP2MAN_$(AM_DEFAULT_VERBOSITY))
AM_V_HELP2MAN_0 = @echo "  HELP2MAN" $@;
AM_V_PO4A = $(AM_V_PO4A_$(V))
AM_V_PO4A_ = $(AM_V_PO4A_$(AM_DEFAULT_VERBOSITY))
AM_V_PO4A_0 = @echo "  PO4A    " $@;
AM_V_POXREF = $(AM_V_POXREF_$(V))
AM_V_POXREF_ = $(AM_V_POXREF_$(AM_DEFAULT_VERBOSITY))
AM_V_POXREF_0 = @echo "  POXREF  " $@;
all: $(BUILT_SOURCES)
	$(MAKE) $(AM_MAKEFLAGS) all-recursive

.SUFFIXES:
.SUFFIXES: .go .c .cc .dot .dvi .eps .log .o .obj .pdf .png .ps .scm .scm$(EXEEXT) .sh .sh$(EXEEXT) .trs
am--refresh: Makefile
	@:
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am $(srcdir)/gnu/local.mk $(srcdir)/po/doc/local.mk $(srcdir)/doc/local.mk $(srcdir)/nix/local.mk $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      echo ' cd $(srcdir) && $(AUTOMAKE) --gnu'; \
	      $(am__cd) $(srcdir) && $(AUTOMAKE) --gnu \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --gnu Makefile'; \
	$(am__cd) $(top_srcdir) && \
	  $(AUTOMAKE) --gnu Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    echo ' $(SHELL) ./config.status'; \
	    $(SHELL) ./config.status;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $@ $(am__maybe_remake_depfiles)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $@ $(am__maybe_remake_depfiles);; \
	esac;
$(srcdir)/gnu/local.mk $(srcdir)/po/doc/local.mk $(srcdir)/doc/local.mk $(srcdir)/nix/local.mk $(am__empty):

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	$(SHELL) ./config.status --recheck

$(top_srcdir)/configure:  $(am__configure_deps)
	$(am__cd) $(srcdir) && $(AUTOCONF)
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	$(am__cd) $(srcdir) && $(ACLOCAL) $(ACLOCAL_AMFLAGS)
$(am__aclocal_m4_deps):

nix/config.h: nix/stamp-h1
	@test -f $@ || rm -f nix/stamp-h1
	@test -f $@ || $(MAKE) $(AM_MAKEFLAGS) nix/stamp-h1

nix/stamp-h1: $(top_srcdir)/nix/config.h.in $(top_builddir)/config.status
	$(AM_V_at)rm -f nix/stamp-h1
	$(AM_V_GEN)cd $(top_builddir) && $(SHELL) ./config.status nix/config.h
$(top_srcdir)/nix/config.h.in:  $(am__configure_deps) 
	$(AM_V_GEN)($(am__cd) $(top_srcdir) && $(AUTOHEADER))
	$(AM_V_at)rm -f nix/stamp-h1
	$(AM_V_at)touch $@

distclean-hdr:
	-rm -f nix/config.h nix/stamp-h1
etc/guix-daemon.cil: $(top_builddir)/config.status $(top_srcdir)/etc/guix-daemon.cil.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
etc/apparmor.d/tunables/guix: $(top_builddir)/config.status $(top_srcdir)/etc/apparmor.d/tunables/guix.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
guix/config.scm: $(top_builddir)/config.status $(top_srcdir)/guix/config.scm.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
etc/committer.scm: $(top_builddir)/config.status $(top_srcdir)/etc/committer.scm.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
test-env: $(top_builddir)/config.status $(top_srcdir)/build-aux/test-env.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
pre-inst-env: $(top_builddir)/config.status $(top_srcdir)/build-aux/pre-inst-env.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
install-binPROGRAMS: $(bin_PROGRAMS)
	@$(NORMAL_INSTALL)
	@list='$(bin_PROGRAMS)'; test -n "$(bindir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(bindir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(bindir)" || exit 1; \
	fi; \
	for p in $$list; do echo "$$p $$p"; done | \
	sed 's/$(EXEEXT)$$//' | \
	while read p p1; do if test -f $$p \
	  ; then echo "$$p"; echo "$$p"; else :; fi; \
	done | \
	sed -e 'p;s,.*/,,;n;h' \
	    -e 's|.*|.|' \
	    -e 'p;x;s,.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/' | \
	sed 'N;N;N;s,\n, ,g' | \
	$(AWK) 'BEGIN { files["."] = ""; dirs["."] = 1 } \
	  { d=$$3; if (dirs[d] != 1) { print "d", d; dirs[d] = 1 } \
	    if ($$2 == $$4) files[d] = files[d] " " $$1; \
	    else { print "f", $$3 "/" $$4, $$1; } } \
	  END { for (d in files) print "f", d, files[d] }' | \
	while read type dir files; do \
	    if test "$$dir" = .; then dir=; else dir=/$$dir; fi; \
	    test -z "$$files" || { \
	      echo " $(INSTALL_PROGRAM_ENV) $(INSTALL_PROGRAM) $$files '$(DESTDIR)$(bindir)$$dir'"; \
	      $(INSTALL_PROGRAM_ENV) $(INSTALL_PROGRAM) $$files "$(DESTDIR)$(bindir)$$dir" || exit $$?; \
	    } \
	; done

uninstall-binPROGRAMS:
	@$(NORMAL_UNINSTALL)
	@list='$(bin_PROGRAMS)'; test -n "$(bindir)" || list=; \
	files=`for p in $$list; do echo "$$p"; done | \
	  sed -e 'h;s,^.*/,,;s/$(EXEEXT)$$//;$(transform)' \
	      -e 's/$$/$(EXEEXT)/' \
	`; \
	test -n "$$list" || exit 0; \
	echo " ( cd '$(DESTDIR)$(bindir)' && rm -f" $$files ")"; \
	cd "$(DESTDIR)$(bindir)" && $(am__rm_f) $$files

clean-binPROGRAMS:
	-$(am__rm_f) $(bin_PROGRAMS)
install-pkglibexecPROGRAMS: $(pkglibexec_PROGRAMS)
	@$(NORMAL_INSTALL)
	@list='$(pkglibexec_PROGRAMS)'; test -n "$(pkglibexecdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(pkglibexecdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(pkglibexecdir)" || exit 1; \
	fi; \
	for p in $$list; do echo "$$p $$p"; done | \
	sed 's/$(EXEEXT)$$//' | \
	while read p p1; do if test -f $$p \
	  ; then echo "$$p"; echo "$$p"; else :; fi; \
	done | \
	sed -e 'p;s,.*/,,;n;h' \
	    -e 's|.*|.|' \
	    -e 'p;x;s,.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/' | \
	sed 'N;N;N;s,\n, ,g' | \
	$(AWK) 'BEGIN { files["."] = ""; dirs["."] = 1 } \
	  { d=$$3; if (dirs[d] != 1) { print "d", d; dirs[d] = 1 } \
	    if ($$2 == $$4) files[d] = files[d] " " $$1; \
	    else { print "f", $$3 "/" $$4, $$1; } } \
	  END { for (d in files) print "f", d, files[d] }' | \
	while read type dir files; do \
	    if test "$$dir" = .; then dir=; else dir=/$$dir; fi; \
	    test -z "$$files" || { \
	      echo " $(INSTALL_PROGRAM_ENV) $(INSTALL_PROGRAM) $$files '$(DESTDIR)$(pkglibexecdir)$$dir'"; \
	      $(INSTALL_PROGRAM_ENV) $(INSTALL_PROGRAM) $$files "$(DESTDIR)$(pkglibexecdir)$$dir" || exit $$?; \
	    } \
	; done

uninstall-pkglibexecPROGRAMS:
	@$(NORMAL_UNINSTALL)
	@list='$(pkglibexec_PROGRAMS)'; test -n "$(pkglibexecdir)" || list=; \
	files=`for p in $$list; do echo "$$p"; done | \
	  sed -e 'h;s,^.*/,,;s/$(EXEEXT)$$//;$(transform)' \
	      -e 's/$$/$(EXEEXT)/' \
	`; \
	test -n "$$list" || exit 0; \
	echo " ( cd '$(DESTDIR)$(pkglibexecdir)' && rm -f" $$files ")"; \
	cd "$(DESTDIR)$(pkglibexecdir)" && $(am__rm_f) $$files

clean-pkglibexecPROGRAMS:
	-$(am__rm_f) $(pkglibexec_PROGRAMS)

