	  doc/guix-cookbook.fr.t2d doc/guix-cookbook.fr.t2p \
	  doc/guix-cookbook.it.t2d doc/guix-cookbook.it.t2p \
	  doc/guix-cookbook.ko.t2d doc/guix-cookbook.ko.t2p \
	  doc/guix-cookbook.pt_BR.t2d doc/guix-cookbook.pt_BR.t2p \
	  doc/guix-cookbook.ru.t2d doc/guix-cookbook.ru.t2p \
