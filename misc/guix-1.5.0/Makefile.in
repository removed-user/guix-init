$(srcdir)/doc/stamp-7: doc/guix.zh_CN.texi $(top_srcdir)/configure
	@test -f doc/$(am__dirstamp) || $(MAKE) $(AM_MAKEFLAGS) doc/$(am__dirstamp)
	@(dir=.; test -f ./doc/guix.zh_CN.texi || dir=$(srcdir); \
	set `$(SHELL) $(top_srcdir)/build-aux/mdate-sh $$dir/doc/guix.zh_CN.texi`; \
	echo "@set UPDATED $$1 $$2 $$3"; \
	echo "@set UPDATED-MONTH $$2 $$3"; \
	echo "@set EDITION $(VERSION)"; \
	echo "@set VERSION $(VERSION)") > 7.tmp$$$$ && \
	(cmp -s 7.tmp$$$$ $(srcdir)/doc/version-zh_CN.texi \
	  || (echo "Updating $(srcdir)/doc/version-zh_CN.texi" && \
	      cp 7.tmp$$$$ $(srcdir)/doc/version-zh_CN.texi.tmp$$$$ && \
	      mv $(srcdir)/doc/version-zh_CN.texi.tmp$$$$ $(srcdir)/doc/version-zh_CN.texi)) && \
	rm -f 7.tmp$$$$ $(srcdir)/doc/version-zh_CN.texi.$$$$
	@cp $(srcdir)/doc/version-zh_CN.texi $@

