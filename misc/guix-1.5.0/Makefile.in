distclean-generic:
	-$(am__rm_f) $(CONFIG_CLEAN_FILES)
	-test . = "$(srcdir)" || $(am__rm_f) $(CONFIG_CLEAN_VPATH_FILES)
	-$(am__rm_f) doc/$(am__dirstamp)
	-$(am__rm_f) gnu/packages/aux-files/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) gnu/packages/aux-files/$(am__dirstamp)
	-$(am__rm_f) nix/libstore/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) nix/libstore/$(am__dirstamp)
	-$(am__rm_f) nix/libutil/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) nix/libutil/$(am__dirstamp)
	-$(am__rm_f) nix/nix-daemon/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) nix/nix-daemon/$(am__dirstamp)

maintainer-clean-generic:
	@echo "This command is intended for maintainers to use"
	@echo "it deletes files that may require special tools to rebuild."
	-$(am__rm_f) $(BUILT_SOURCES)
	-$(am__rm_f) $(MAINTAINERCLEANFILES)
