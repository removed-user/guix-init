3.9 Ejecución de Guix en un servidor Kimsufi
============================================

Para ejecutar Guix en un servidor alojado en Kimsufi
(https://www.kimsufi.com/), haz clic en la pestaña netboot, selecciona
rescue64-pro y reinicia.

   OVH le enviará por correo electrónico las credenciales necesarias
para entrar por ssh en un sistema Debian.

   Ahora puede ejecutar los pasos "instalar guix desde *note
(guix)Instalación binaria::":

     wget https://git.savannah.gnu.org/cgit/guix.git/plain/etc/guix-install.sh
     chmod +x guix-install.sh
     ./guix-install.sh
     guix pull

   Particionar los discos y formatearlos, primero parar el raid array:

     mdadm --stop /dev/md127
     mdadm --zero-superblock /dev/sda2 /dev/sdb2

   A continuación, limpie los discos y configurar las particiones, vamos
a crear una matriz RAID 1.

     wipefs -a /dev/sda
     wipefs -a /dev/sdb

     parted /dev/sda --align=opt -s -m -- mklabel gpt
     parted /dev/sda --align=opt -s -m -- \
      mkpart bios_grub 1049kb 512MiB \
      set 1 bios_grub on
     parted /dev/sda --align=opt -s -m -- \
      mkpart primary 512MiB -512MiB
      set 2 raid on
     parted /dev/sda --align=opt -s -m -- mkpart primary linux-swap 512MiB 100%

     parted /dev/sdb --align=opt -s -m -- mklabel gpt
     parted /dev/sdb --align=opt -s -m -- \
          mkpart bios_grub 1049kb 512MiB \
          set 1 bios_grub on
     parted /dev/sdb --align=opt -s -m -- \
          mkpart primary 512MiB -512MiB \
          set 2 raid on
     parted /dev/sdb --align=opt -s -m -- mkpart primary linux-swap 512MiB 100%

   Crea el array:

     mdadm --create /dev/md127 --level=1 --raid-disks=2 \
       --metadata=0.90 /dev/sda2 /dev/sdb2

   Ahora cree sistemas de archivos en las particiones relevantes,
primero las particiones de arranque:

     mkfs.ext4  /dev/sda1
     mkfs.ext4  /dev/sdb1

   A continuación, la partición raíz:

     mkfs.ext4 /dev/md127

   Inicializar las particiones swap:

     mkswap /dev/sda3
     swapon /dev/sda3
     mkswap /dev/sdb3
     swapon /dev/sdb3

   Monte la unidad guix:

     mkdir /mnt/guix
     mount /dev/md127 /mnt/guix

   Ahora es el momento de escribir una declaración del sistema operativo
del archivo ‘os.scm’; aquí tiene una muestra:

     (use-modules (gnu) (guix))
     (use-service-modules networking ssh vpn virtualization sysctl admin mcron)
     (use-package-modules ssh tls tmux vpn virtualization)

     (operating-system
       (host-name "kimsufi")

       (bootloader (bootloader-configuration
     	       (bootloader grub-bootloader)
     	       (targets (list "/dev/sda" "/dev/sdb"))
     	       (terminal-outputs '(console))))

       ;; Añadir un módulo de kernel para RAID-1 (aka. "mirror").
       (initrd-modules (cons* "raid1"  %base-initrd-modules))

       (mapped-devices
        (list (mapped-device
               (source (list "/dev/sda2" "/dev/sdb2"))
               (target "/dev/md127")
               (type raid-device-mapping))))

       (swap-devices
        (list (swap-space
               (target "/dev/sda3"))
              (swap-space
               (target "/dev/sdb3"))))

       (issue
        ;; Default contents for /etc/issue.
        "\
     Este es el sistema GNU en Kimsufi.  Bienvenido.\n")

       (file-systems (cons* (file-system
     		         (mount-point "/")
     		         (device "/dev/md127")
     		         (type "ext4")
     		         (dependencies mapped-devices))
     		       %base-file-systems))

       (users (cons (user-account
     	        (name "guix")
     	        (comment "guix")
     	        (group "users")
     	        (supplementary-groups '("wheel"))
     	        (home-directory "/home/guix"))
     	       %base-user-accounts))

       (sudoers-file
        (plain-file "sudoers" "\
     root ALL=(ALL) ALL
     %wheel ALL=(ALL) ALL
     guix ALL=(ALL) NOPASSWD:ALL\n"))

       ;; Paquetes instalados globalmente.
       (packages (cons* tmux gnutls wireguard-tools %base-packages))
       (services
        (cons*
         (service static-networking-service-type
     	     (list (static-networking
     		    (addresses (list (network-address
     				      (device "enp3s0")
     				      (value "SERVER-IP-ADDRESS/24"))))
     		    (routes (list (network-route
     				   (destination "default")
     				   (gateway "SERVER-GATEWAY"))))
     		    (name-servers '("213.186.33.99")))))

         (service unattended-upgrade-service-type)

         (service openssh-service-type
     	     (openssh-configuration
     	      (openssh openssh-sans-x)
     	      (permit-root-login #f)
     	      (authorized-keys
     	       `(("guix" ,(plain-file "SSH-KEY-NAME.PUB"
                                           "SSH-PUBLIC-KEY-CONTENT"))))))
         (modify-services %base-services
           (sysctl-service-type
            config =>
            (sysctl-configuration
     	(settings (append '(("net.ipv6.conf.all.autoconf" . "0")
     			    ("net.ipv6.conf.all.accept_ra" . "0"))
     			  %default-sysctl-settings))))))))

   No olvide sustituir el SERVER-IP-ADDRESS, SERVER-GATEWAY,
SSH-KEY-NAME y SSH-PUBLIC-KEY-CONTENT con sus propios valores.

   La puerta de enlace es la última IP utilizable de su bloque, por lo
que si tiene un servidor con una IP de ‘37.187.79.10’ entonces su puerta
de enlace será ‘37.187.79.254’.

   Transfiera su declaración de sistema operativo ‘os.scm’ en el
servidor a través de ‘scp’ o comandos ‘sftp’.

   Ahora sólo queda instalar Guix con un ‘guix system init’ y reinicia.

   Sin embargo, primero necesitamos configurar un chroot, porque la
partición raíz del sistema de rescate está montada en una partición aufs
y si intentas instalar Guix fallará en el paso de instalación de GRUB
quejándose de la ruta canónica de "aufs".

   Instala los paquetes que se utilizarán en el chroot:

     guix install bash-static parted util-linux-with-udev coreutils guix

   A continuación, ejecute lo siguiente para crear los directorios
necesarios para el chroot:

     cd /mnt && \
     mkdir -p bin etc gnu/store root/.guix-profile/ root/.config/guix/current \
       var/guix proc sys dev

   Copie el host resolv.conf en el chroot:

     cp /etc/resolv.conf etc/

   Montar dispositivos de bloque, el almacén y su base de datos y la
configuración guix actual:

     mount --rbind /proc /mnt/proc
     mount --rbind /sys /mnt/sys
     mount --rbind /dev /mnt/dev
     mount --rbind /var/guix/ var/guix/
     mount --rbind /gnu/store gnu/store/
     mount --rbind /root/.config/ root/.config/
     mount --rbind /root/.guix-profile/bin/ bin
     mount --rbind /root/.guix-profile root/.guix-profile/

   Chroot en /mnt e instalar el sistema:

     chroot /mnt/ /bin/bash

     guix system init /root/os.scm /guix

   Por último, desde la interfaz de usuario web (UI), cambia ‘netboot’
por ‘boot to disk’ y reinicia (también desde la UI web).

   Espera unos minutos e intenta hacer ssh con ‘ssh
guix@DIRECCIÓN-IP-DEL-SERVIDOR> -i PATH-TO-YOUR-SSH-KEY’.

   Deberías tener un sistema Guix funcionando en Kimsufi; ¡enhorabuena!


File: guix-cookbook.es.info,  Node: Instalar un montaje enlazado,  Next: Obtener sustituciones desde Tor,  Prev: Ejecución de Guix en un servidor Kimsufi,  Up: Configuración del sistema

3.10 Instalar un montaje enlazado
=================================

Para enlazar el montaje de un sistema de archivos, primero hay que
establecer algunas definiciones antes de la sección ‘operating-system’
de la definición del sistema. En este ejemplo vamos a bind mount una
carpeta de una unidad de disco giratorio a ‘/tmp’, para ahorrar desgaste
en el SSD primario, sin dedicar una partición entera a ser montada como
‘/tmp’.

   En primer lugar, debe definirse la unidad de origen que aloja la
carpeta que deseamos montar de forma enlazada, para que el montaje
enlazado pueda depender de ella.

     (define source-drive ;; "source-drive" puede llamarse como quieras.
        (file-system
         (device (uuid "UUID goes here"))
         (mount-point "/path-to-spinning-disk-goes-here")
         (type "ext4"))) ;Asegúrese de establecer el tipo adecuado para su unidad..

   También debe definirse la carpeta de origen, para que guix sepa que
no se trata de un dispositivo de bloque normal, sino de una carpeta.
     ;; "source-directory" puede denominarse con cualquier nombre de variable válido.
     (define (%source-directory) "/path-to-spinning-disk-goes-here/tmp")

   Por último, dentro del ‘file-systems’ definición, debemos añadir el
propio montaje.

     (file-systems (cons*

                     ...<otras unidades omitidas para mayor claridad>...

                     ;; Debe coincidir con el nombre que le diste a la unidad de origen en la definición anterior.
                     source-drive

                     (file-system
                      ;; Asegúrese de que "directorio-fuente" coincide con su definición anterior.
                      (device (%source-directory))
                      (mount-point "/tmp")
                      ;; Estamos montando una carpeta, no una partición, por lo que este tipo debe ser "none"
                      (type "none")
                      (flags '(bind-mount))
                      ;; Asegúrese de que "source-drive" coincide con el nombre que ha dado a la variable de la unidad..
                      (dependencies (list source-drive))
                      )

                      ...<otras unidades omitidas para mayor claridad>...

                     ))


